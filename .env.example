# Copy this to .env and fill in the values

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Allowed redirect URI registered in Google Cloud Console
# For local dev: http://localhost:8000/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Database — for local dev (outside docker-compose) set this to your local postgres
DATABASE_URL=postgresql+asyncpg://bookclub:bookclub@localhost:5432/bookclub

# Discord notifications (optional — leave empty to disable)
DISCORD_WEBHOOK_URL=

# App settings
APP_BASE_URL=http://localhost:8000
